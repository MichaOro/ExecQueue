{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": [
    "adesso",
    "openrouter",
    "adesso-ai-paid-hub"
  ],
  "provider": {
    "adesso": {
      "name": "adesso-ai-hub",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://adesso-ai-hub.3asabc.de/v1"
      },
      "models": {
        "gpt-oss-120b-sovereign": {
          "name": "gpt-oss-120b-sovereign",
          "tool_call": true
        },
        "qwen-3.5-122b-sovereign": {
          "name": "qwen-3.5-122b-sovereign",
          "tool_call": true
        }
      }
    },
    "adesso-ai-paid-hub": {
      "name": "adesso-ai-paid-hub",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://adesso-ai-hub.3asabc.de/v1"
      },
      "models": {
        "gpt-oss-120b-sovereign": {
          "name": "gpt-oss-120b-sovereign",
          "tool_call": true
        },
        "qwen3-coder-480b": {
          "name": "qwen3-coder-480b",
          "tool_call": false
        },
        "gemini-2.5-pro": {
          "name": "gemini-2.5-pro",
          "tool_call": true
        },
        "claude-sonnet-4-6*": {
          "name": "claude-sonnet-4-6*",
          "tool_call": true
        }
      }
    }
  },
  "model": "adesso/qwen-3.5-122b-sovereign",
  "small_model": "gpt-oss-120b-sovereign",
  "default_agent": "build",
  "share": "disabled",
  "instructions": [
    "./.opencode/instructions/engineering.md",
    "./.opencode/instructions/git-safety.md",
    "./.opencode/instructions/mcp-usage.md"
  ],
  "watcher": {
    "ignore": [
      ".git/**",
      ".pytest_cache/**",
      "**/__pycache__/**",
      "**/*.pyc",
      "execqueue.egg-info/**",
      "ops/logs/**",
      "ops/pids/**"
    ]
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 20000
  },
  "permission": {
    "*": "allow",
    "read": {
      "*": "allow"
    },
    "skill": {
      "*": "allow"
    },
    "task": "allow",
    "external_directory": {
      "*": "allow"
    },
    "bash": {
      "*": "allow"
    },
    "git_*": "deny",
    "postgres_*": "deny"
  },
  "mcp": {
    "filesystem": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        ".",
        "{env:TEMP}",
        "{env:TMP}"
      ],
      "enabled": true
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true
    },
    "postgres": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://localhost/postgres"
      ],
      "enabled": true
    },
    "git": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@cyanheads/git-mcp-server@latest"
      ],
      "enabled": true
    }
  },
  "agent": {
    "build": {
      "description": "Primary delivery agent for ExecQueue. Writes directly into the project while staying within the local worktree and repo safety rules.",
      "mode": "primary",
      "temperature": 0.2,
      "prompt": "{file:./.opencode/prompts/build.md}",
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow"
        },
        "task": "allow"
      }
    },
    "plan": {
      "description": "Primary planning agent for analysis, architecture thinking, and safe recommendations without changing files.",
      "mode": "primary",
      "temperature": 0.1,
      "prompt": "{file:./.opencode/prompts/plan.md}",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "allow"
        },
        "git_*": "deny",
        "postgres_*": "deny"
      }
    },
    "review": {
      "description": "Read-only review subagent focused on bugs, regressions, missing tests, and maintainability.",
      "mode": "subagent",
      "temperature": 0.1,
      "prompt": "{file:./.opencode/prompts/review.md}",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "task": "deny",
        "git_*": "deny",
        "postgres_*": "deny"
      }
    },
    "db-inspector": {
      "description": "Subagent for schema and data inspection through the postgres MCP, intended for read-only exploration.",
      "mode": "subagent",
      "temperature": 0.0,
      "prompt": "{file:./.opencode/prompts/db-inspector.md}",
      "permission": {
        "postgres_*": "allow",
        "edit": "deny",
        "bash": "deny",
        "task": "deny",
        "git_*": "deny"
      }
    },
    "db-writer": {
      "description": "Subagent for explicit database write operations. Always requires approval before using Postgres MCP tools.",
      "mode": "subagent",
      "temperature": 0.0,
      "prompt": "{file:./.opencode/prompts/db-writer.md}",
      "permission": {
        "postgres_*": "allow",
        "edit": "deny",
        "bash": "deny",
        "task": "deny",
        "git_*": "deny"
      }
    },
    "context-curator": {
      "description": "Subagent for phase-based context compression and continuation-safe state updates. Never implements code.",
      "mode": "subagent",
      "model": "adesso/gpt-oss-120b-sovereign",
      "temperature": 0.0,
      "prompt": "You are a context curator for ExecQueue. Your only job is to create or refresh a continuation-safe working state. Do not implement code, do not invent facts, and prefer repository truth over session memory. Keep outputs compact, structured, and restart-friendly.",
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow"
        },
        "git_*": "allow"
      }
    }
  }
}
