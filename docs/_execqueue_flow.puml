@startuml
title ExecQueue – Event-getriebener Task Flow mit OpenCode Serve

start
<style>
activity {
  BackgroundColor #006400
  FontColor white
}
</style>

:task_type = requirement;
:Artefakt wird erfasst;

if (Artefakt-Typ gültig?) then (ja)

  if (Requirement?) then (ja)
    :task_type = requirement;
  elseif (Direkter Task?) then (ja)
    :task_type = execution;
  elseif (Planning Task?) then (ja)
    :task_type = planning;
  elseif (Analyse Task?) then (ja)
    :task_type = analysis;
  else (nein)
    :task_type = unknown;
  endif

  :Task erzeugen;
  :Task Status = backlog;
  :Task speichern;

else (nein)
  :Artefakt ablehnen;
  :Fehler / Validierungsstatus speichern;
  stop
endif

repeat

  :Orchestrator-Trigger auslösen\n;
  :Orchestrator prüft ausführbare Tasks;

  if (Ausführbare Tasks vorhanden?) then (ja)

    repeat

      :Ausführbaren Task ermitteln;

      if (Task benötigt Schreibzugriff?) then (ja)

        if (Task parallelisierbar?) then (ja)
          :Task für parallelen Write-Batch vormerken;
        else (nein)
          :Task für sequenziellen Write-Batch vormerken;
        endif

      else (nein)
      endif

      :Task für atomaren Lock vormerken;

    repeat while (Parallelisierbare Tasks vorhanden?) is (ja)

    :Vorgemerkte Tasks atomar locken;
    :Task Status = queued;

    repeat

      :Gelockten Task vorbereiten;

      if (Task benötigt Schreibzugriff?) then (ja)

        if (Task hat bereits Worktree?) then (ja)
          :Vorhandenen Worktree verwenden;
        else (nein)

          if (Git Branch definiert?) then (ja)
            :Definierten Git Branch verwenden;
          else (nein)
            :Git Branch für Task erzeugen;
            :Branch am Task speichern;
          endif

          :Eigenen Git Worktree erzeugen;
          :Worktree am Task speichern;

        endif

      else (nein)
        :Read-only / Analyse- / Planning-Kontext verwenden;
        :Keine Worktree-Isolation notwendig;
      endif
      <style>
activity {
  BackgroundColor #F1F1F1
  FontColor black
}
</style>

:task_type = requirement;
      :Task Runner initialisieren;
      :OpenCode Session erzeugen;
      :session_id persistieren;
      :OpenCode Mode setzen;

      if (Task benötigt Schreibzugriff?) then (ja)
        :Worktree-Kontext einbinden;
      else (nein)
      endif

      :Task Status = in_progress;

      repeat

        :Task durch OpenCode ausführen;

        if (Logging aktiviert?) then (ja)
          :Logs persistieren;
        endif

        :Runner-Ergebnis bewerten;

        if (Ausführung erfolgreich?) then (ja)

          :Result speichern;

          if (Task benötigt Schreibzugriff?) then (ja)

            :Worktree Diff prüfen;

            if (Worktree-Änderungen vorhanden?) then (ja)
              :Validierung ausführen\n(Build / Tests / Lint);

              if (Validierung erfolgreich?) then (ja)

                repeat

                  :Commit im Task-Worktree prüfen;



                  :commit_sha persistieren;
                  :Diff / Commit-Metadaten speichern;

                  :Commit in Ziel-Branch übernehmen;
                  :Ziel-Branch Commit validieren;

                  if (Ziel-Branch Commit erfolgreich?) then (ja)
                    :target_commit_sha persistieren;
                    :Task Status = review;
                  else (nein)
                    :Commit-Transfer-Fehler speichern;

                    if (Max Commit Retry Count erreicht?) then (ja)
                      :Task Status = failed;
                    else (nein)
                      :Commit Retry Count erhöhen;
                      :Task bleibt in_progress;
                    endif

                  endif

                repeat while (Task Status = in_progress\nund Commit Retry Count nicht erreicht?) is (ja)

              else (nein)
                :Validierungsfehler speichern;

                if (Max Validation Retry Count erreicht?) then (ja)
                  :Task Status = failed;
                else (nein)
                  :Validation Retry Count erhöhen;
                  :Task bleibt in_progress;
                endif

              endif

            else (nein)
              :Task Status = done;
            endif

          else (nein)
            :Task Status = done;
          endif

        else (nein)
          :Ausführungsfehler speichern;

          if (Max Execution Retry Count erreicht?) then (ja)
            :Task Status = failed;
          else (nein)
            :Execution Retry Count erhöhen;
            :Task bleibt in_progress;
          endif

        endif

      repeat while (Task Status = in_progress\nund Retry Count nicht erreicht?) is (ja)

      :Runner abschließen;

      if (Task benötigt Schreibzugriff?) then (ja)
        :Worktree-Status dokumentieren;
        :Branch / Commit für Review bereitstellen;
      endif

      :Abhängigkeiten und aggregierte Status aktualisieren;

    repeat while (Weitere gelockte Tasks im Batch vorhanden?) is (ja)

  else (nein)
    :Keine aktuell ausführbaren Tasks;
  endif

repeat while (Weitere ausführbare Tasks vorhanden?) is (ja)

:Orchestrator-Lauf beenden;
:Orchestrator bleibt idle bis zum nächsten Trigger;

stop

@enduml